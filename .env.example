# GitLab
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=your_gitlab_token
GITLAB_PROJECT_ID=123456
GITLAB_WEBHOOK_SECRET=change-me

# AI Provider
MODEL_PROVIDER=openai
MODEL_NAME=gpt-4.1-mini
OPENAI_API_KEY=your_openai_key
OPENAI_BASE_URL=https://api.openai.com/v1

# Hugging Face (if MODEL_PROVIDER=huggingface)
HUGGINGFACE_API_TOKEN=your_hf_token
HUGGINGFACE_MODEL_ID=meta-llama/Meta-Llama-3-8B-Instruct

# Local model endpoint (if MODEL_PROVIDER=local)
LOCAL_MODEL_URL=http://localhost:11434/v1/chat/completions
LOCAL_MODEL_TOKEN=

# Behavior
MAX_FILES_PER_SCAN=300
AUTO_CREATE_MR=false
COMMENT_ON_MR=true
